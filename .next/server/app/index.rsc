ayStation games.","category":"electronics"},{"id":"4","name":"Xbox Series X","price":25000,"image":"/productImages/xbox-series-x.png","description":"The Xbox Series X is Microsoft's powerful, high-performance gaming console designed for an unparalleled next-generation experience , featuring a custom AMD processor, a 1TB SSD for fast loading, Quick Resume to switch between games instantly, DirectX ray tracing for realistic graphics, 4K resolution support, and backward compatibility with thousands of Xbox One, Xbox 360, and original Xbox games.  ","category":"electronics"}]}]]}],["$","section",null,{"className":"m-8","children":[["$","h1",null,{"className":"text-5xl text-center font-bold m-10","children":["Top ",["$","span",null,{"className":"text-yellow-400","children":"Categories"}]]}],["$","div",null,{"className":"grid grid-cols-1 sm:grid-cols-2 md:grid-cols-4 gap-10 max-w-6xl mx-auto mt-5 shadow-lg dark:shadow-gray-700","children":[["$","$L18","1",{"href":"/categories/electronics","className":"bg-white rounded-lg shadow-md overflow-hidden hover:shadow-xl transition-shadow duration-300 cursor-pointer flex flex-col h-full","children":["$","div","1",{"className":"bg-white rounded-lg shadow-md overflow-hidden hover:shadow-xl transition-shadow duration-300 cursor-pointer flex flex-col h-full  dark:bg-gray-800 dark:border-gray-700","children":[["$","img",null,{"src":"HomePage/electronic-cat.png","alt":"Electronics","className":"w-full h-64 object-cover"}],["$","div",null,{"className":"p-4 text-center flex-grow flex flex-col justify-start dark:text-white","children":[["$","h2",null,{"className":"text-2xl font-semibold mb-2 ","children":"Electronics"}],["$","p",null,{"className":"light:text-gray-600 mb-4 dark:text-gray-200","children":"Latest gadgets and tech devices"}]]}]]}]}],"$L19","$L1a","$L1b"]}]]}]]}]
